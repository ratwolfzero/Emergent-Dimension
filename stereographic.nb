Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "parametric", " ", "surface", " ", "function"}],
    "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ParametricSurface", "[", 
      RowBox[{"u_", ",", "v_", ",", "shape_"}], "]"}], ":=", 
     RowBox[{"Switch", "[", 
      RowBox[{"shape", ",", "\"\<sphere\>\"", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Sin", "[", "u", "]"}], " ", 
          RowBox[{"Cos", "[", "v", "]"}]}], ",", 
         RowBox[{
          RowBox[{"Sin", "[", "u", "]"}], " ", 
          RowBox[{"Sin", "[", "v", "]"}]}], ",", 
         RowBox[{"Cos", "[", "u", "]"}]}], "}"}], ",", "\"\<cone\>\"", ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"k", "=", "1"}], ",", 
           RowBox[{"r", "=", "u"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"r", " ", 
            RowBox[{"Cos", "[", "v", "]"}]}], ",", 
           RowBox[{"r", " ", 
            RowBox[{"Sin", "[", "v", "]"}]}], ",", 
           RowBox[{"k", " ", "r"}]}], "}"}]}], "]"}], 
       ",", "\"\<paraboloid\>\"", ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r", "=", "u"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"r", " ", 
            RowBox[{"Cos", "[", "v", "]"}]}], ",", 
           RowBox[{"r", " ", 
            RowBox[{"Sin", "[", "v", "]"}]}], ",", 
           RowBox[{"r", "^", "2"}]}], "}"}]}], "]"}], ",", "_", ",", 
       RowBox[{
       "Throw", 
        "[", "\"\<Unknown shape: Choose 'sphere', 'cone', or 'paraboloid'\>\"",
         "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "stereographic", " ", "projection", " ", 
     "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"StereographicProjection", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "-", "z"}], "==", "0"}], ",", "Nothing", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "/", 
          RowBox[{"(", 
           RowBox[{"1", "-", "z"}], ")"}]}], ",", 
         RowBox[{"y", "/", 
          RowBox[{"(", 
           RowBox[{"1", "-", "z"}], ")"}]}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "inverse", " ", "projection", " ", 
     "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"InverseProjection", "[", 
      RowBox[{"xProj_", ",", "yProj_", ",", "shape_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rProj", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"xProj", "^", "2"}], "+", 
           RowBox[{"yProj", "^", "2"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"Switch", "[", 
        RowBox[{"shape", ",", "\"\<sphere\>\"", ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"denom", "=", 
             RowBox[{"1", "+", 
              RowBox[{"rProj", "^", "2"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", " ", "xProj"}], ")"}], "/", "denom"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", " ", "yProj"}], ")"}], "/", "denom"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", 
                RowBox[{"rProj", "^", "2"}]}], ")"}], "/", "denom"}]}], 
            "}"}]}], "]"}], ",", "\"\<cone\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"xProj", ",", "yProj", ",", "rProj"}], "}"}], 
         ",", "\"\<paraboloid\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"xProj", ",", "yProj", ",", 
           RowBox[{"rProj", "^", "2"}]}], "}"}], ",", "_", ",", 
         RowBox[{
         "Throw", 
          "[", "\"\<Unknown shape: Choose 'sphere', 'cone', or 'paraboloid'\>\
\"", "]"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Select", " ", "shape"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"shapeType", "=", "\"\<cone\>\""}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "Change", " ", "this", " ", "to", " ", "test", " ", "different", " ", 
     "shapes"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generate", " ", "a", " ", "parametric", " ", "surface"}], "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"uRes", "=", "20"}], ";", 
    RowBox[{"vRes", "=", "40"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "Reduced", " ", "resolution", " ", "for", " ", "better", " ", "grid", " ",
      "visibility"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"u", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"shapeType", "==", "\"\<sphere\>\""}], ",", 
       RowBox[{"Subdivide", "[", 
        RowBox[{"0.01", ",", "Pi", ",", 
         RowBox[{"uRes", "-", "1"}]}], "]"}], ",", 
       RowBox[{"Subdivide", "[", 
        RowBox[{"0", ",", "1", ",", 
         RowBox[{"uRes", "-", "1"}]}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"v", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"0", ",", 
       RowBox[{"2", " ", "Pi"}], ",", 
       RowBox[{"vRes", "-", "1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "meshgrid", " ", "using", " ", "Table"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"uMesh", ",", "vMesh"}], "}"}], "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"u", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"v", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "uRes"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "vRes"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "parametric", " ", "surface"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"ParametricSurface", "@@@", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"uMesh", ",", "vMesh", ",", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"shapeType", ",", 
            RowBox[{"Length", "[", "uMesh", "]"}]}], "]"}]}], "}"}], "]"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Apply", " ", "stereographic", " ", "projection", " ", "and", " ", 
     "filter", " ", "invalid", " ", "points"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xProjFiltered", ",", "yProjFiltered"}], "}"}], "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{
        RowBox[{"StereographicProjection", "@@@", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y", ",", "z"}], "}"}], "]"}]}], ",", 
        "Nothing"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Reconstruct", " ", "the", " ", "surface", " ", "using", " ", "inverse", " ",
      "projection"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xRecon", ",", "yRecon", ",", "zRecon"}], "}"}], "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"InverseProjection", "@@@", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"xProjFiltered", ",", "yProjFiltered", ",", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"shapeType", ",", 
            RowBox[{"Length", "[", "xProjFiltered", "]"}]}], "]"}]}], "}"}], 
        "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Reshape", " ", "reconstructed", " ", "points", " ", "into", " ", "2", 
     "D", " ", "arrays"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xRecon2D", ",", "yRecon2D", ",", "zRecon2D"}], "}"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"ArrayReshape", "[", 
        RowBox[{"#", ",", 
         RowBox[{"{", 
          RowBox[{"uRes", ",", "vRes"}], "}"}]}], "]"}], "&"}], "/@", 
      RowBox[{"{", 
       RowBox[{"xRecon", ",", "yRecon", ",", "zRecon"}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "figure", " ", "with", " ", "3", " ", "subplots"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Final", " ", "output"}], "*)"}], 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"(*", 
       RowBox[{"Original", " ", "3", "D", " ", "Surface"}], "*)"}], 
      RowBox[{
       RowBox[{"ParametricPlot3D", "[", 
        RowBox[{
         RowBox[{"ParametricSurface", "[", 
          RowBox[{"u", ",", "v", ",", "shapeType"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"u", ",", "0.01", ",", "Pi"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"v", ",", "0", ",", 
           RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
         RowBox[{"PlotStyle", "->", "Cyan"}], ",", 
         RowBox[{"BoxRatios", "->", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}],
          ",", 
         RowBox[{"Mesh", "->", "All"}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"\"\<Original 3D \>\"", "<>", 
           RowBox[{"ToUpperCase", "[", "shapeType", "]"}]}]}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"2", "D", " ", "Projection"}], "*)"}], 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"xProjFiltered", ",", "yProjFiltered"}], "}"}], "]"}], ",", 
         RowBox[{"PlotStyle", "->", "Blue"}], ",", 
         RowBox[{"PlotRange", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "->", "1"}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<X'\>\"", ",", "\"\<Y'\>\""}], "}"}]}], ",", 
         RowBox[{
         "PlotLabel", 
          "->", "\"\<2D Projection (Holographic Encoding)\>\""}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Reconstructed", " ", "3", "D", " ", "Surface"}], "*)"}], 
       RowBox[{"Graphics3D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Red", ",", "Thick", ",", 
           RowBox[{"Line", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"xRecon2D", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
                  RowBox[{"yRecon2D", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
                  RowBox[{"zRecon2D", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"j", ",", "1", ",", "vRes"}], "}"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", "uRes"}], "}"}]}], "]"}], "]"}], ",", 
           RowBox[{"Line", "[", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"xRecon2D", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
                  RowBox[{"yRecon2D", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
                  RowBox[{"zRecon2D", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "1", ",", "uRes"}], "}"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "1", ",", "vRes"}], "}"}]}], "]"}], "]"}]}], 
          "}"}], ",", 
         RowBox[{"BoxRatios", "->", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], ",", 
         RowBox[{"Axes", "->", "True"}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}],
          ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"\"\<Reconstructed 3D \>\"", "<>", 
           RowBox[{"ToUpperCase", "[", "shapeType", "]"}]}]}]}], "]"}]}], 
      "}"}], ",", 
     RowBox[{"ImageSize", "->", "Full"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.948736094295312*^9, 3.9487360942978477`*^9}, {
  3.948736228015109*^9, 3.948736276346511*^9}},
